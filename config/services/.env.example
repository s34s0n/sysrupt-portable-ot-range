# Sysrupt OT Range - environment configuration
# Copy to .env and edit as required. .env is gitignored.

# -----------------------------------------------------------------------------
# Network zones
# -----------------------------------------------------------------------------
CORP_SUBNET=10.0.1.0/24
CORP_GATEWAY=10.0.1.1
DMZ_SUBNET=10.0.2.0/24
DMZ_GATEWAY=10.0.2.1
SCADA_SUBNET=10.0.3.0/24
SCADA_GATEWAY=10.0.3.1
PROCESS_SUBNET=10.0.4.0/24
PROCESS_GATEWAY=10.0.4.1
SAFETY_SUBNET=10.0.5.0/24
SAFETY_GATEWAY=10.0.5.1

# -----------------------------------------------------------------------------
# Service IP addresses
# -----------------------------------------------------------------------------
CORP_WEB_IP=10.0.1.10
HISTORIAN_IP=10.0.2.10
OPCUA_GATEWAY_IP=10.0.2.30
SCADA_HMI_IP=10.0.3.10
ENGINEERING_WS_IP=10.0.3.20
IDS_MONITOR_IP=10.0.3.30
PLC_INTAKE_IP=10.0.4.101
PLC_CHEMICAL_IP=10.0.4.102
PLC_FILTRATION_IP=10.0.4.103
PLC_DISTRIBUTION_IP=10.0.4.104
PLC_POWER_IP=10.0.4.105
BMS_BACNET_IP=10.0.1.20
SAFETY_SIS_IP=10.0.5.201
SCADA_PROCESS_IP=10.0.4.10
EWS_PROCESS_IP=10.0.4.20
EWS_SAFETY_IP=10.0.5.20
SAFETY_BRIDGE_PORT=10102
EWS_SSH_USER=engineer
EWS_SSH_PASS=eng2024!

# -----------------------------------------------------------------------------
# Credentials (INTENTIONALLY WEAK - training environment only)
# -----------------------------------------------------------------------------
CORP_ADMIN_USER=admin
CORP_ADMIN_PASS=Password123
HISTORIAN_DB_USER=historian
HISTORIAN_DB_PASS=histor1an
HISTORIAN_DB_NAME=plant_data
SCADA_HMI_USER=operator
SCADA_HMI_PASS=operator
ENGINEERING_USER=engineer
ENGINEERING_PASS=siemens
OPCUA_USER=opcua
OPCUA_PASS=opcua123

# -----------------------------------------------------------------------------
# Physics simulation
# -----------------------------------------------------------------------------
PHYSICS_TICK_HZ=10
PHYSICS_REAL_TIME=true
PHYSICS_RANDOM_SEED=1337

# -----------------------------------------------------------------------------
# CTF
# -----------------------------------------------------------------------------
CTF_FLAG_PREFIX=SYSRUPT
CTF_SCOREBOARD_PORT=8080
CTF_HINT_DELAYS=15,30,45

# -----------------------------------------------------------------------------
# Display
# -----------------------------------------------------------------------------
DISPLAY_ENABLED=true
DISPLAY_ROTATION=0
DISPLAY_BRIGHTNESS=100

# -----------------------------------------------------------------------------
# Redis (event bus / state store)
# -----------------------------------------------------------------------------
REDIS_HOST=127.0.0.1
REDIS_PORT=6379
REDIS_DB=0

# -----------------------------------------------------------------------------
# Protocol ports (session 5: multi-protocol PLCs)
# -----------------------------------------------------------------------------
DNP3_PORT=20000
ENIP_PORT=44818
IEC104_PORT=2404
BACNET_PORT=47808
